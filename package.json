{
  "name": "careers-mt-vercel",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run build && firebase emulators:start --only hosting,firestore",
    "build": "node scripts/build-config.js && echo 'Building static site...'",
    "deploy": "firebase deploy --only firestore,hosting",
    "lint": "eslint . --ext .js,.ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
