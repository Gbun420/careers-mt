    "@vercel/analytics": "^2.0.1",
    "dotenv": "^17.3.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.2.2",
    "genkit": "^1.30.1",
    "genkitx-groq": "^0.30.0",
    "groq-sdk": "^1.1.1",
    "ioredis": "^5.10.1",
    "rate-limiter-flexible": "^10.0.1",
    "redis": "^5.11.0",
    "resend": "^6.9.4",
    "stripe": "^20.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@vercel/node": "^5.6.18",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-security": "^4.0.0",
    "snyk": "^1.1303.2",
    "ts-node": "^10.9.2",
