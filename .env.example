# ----- AI Providers -----
GROQ_API_KEY=your-groq-api-key

# ----- Firebase -----

FIREBASE_PROJECT_ID=your-firebase-project-id
# Preferred (build-config reads this)
NEXT_PUBLIC_FIREBASE_CONFIG='{"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"...","measurementId":"..."}'
# Legacy fallback (still supported)
FIREBASE_CLIENT_CONFIG='{"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"...","measurementId":"..."}'

# ----- App Check (optional but recommended) -----

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# ----- Stripe (for paid tiers) -----

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ----- Email provider (Resend, SendGrid, etc.) -----

RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=<noreply@careers.mt>

# ----- Misc -----

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-gmaps-key
